DATABASE_URL=postgresql://cleardesk:cleardesk@localhost:5432/cleardesk
JWT_SECRET=change-me

# LLM provider: mock | gemini | ollama | anthropic
# mock   = no key, no network — canned agent responses, full app runs (default)
# gemini = FREE tier, vision-capable: get a key at https://aistudio.google.com/apikey
# ollama = fully local & free: install from https://ollama.com, then `ollama pull llama3.2-vision`
LLM_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision

ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5

UPLOAD_DIR=uploads
MAX_CROSS_VERIFY_ROUNDS=3
